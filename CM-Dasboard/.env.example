# Database settings (used in Docker PostgreSQL container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=complaint_db

# App settings
SECRET_KEY=YOUR_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION
REFRESH_SECRET_KEY=YOUR_REFRESH_SECRET_KEY_CHANGE_IN_PRODUCTION
ACCESS_TOKEN_EXPIRE_MINUTES=15

# SMTP settings (for citizen feedback & verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAILS_FROM_EMAIL=no-reply@delhi.gov.in

# Redis Settings (used by rate limiter & analytics caching)
REDIS_URL=redis://redis:6379/0

# Optional AWS S3 settings for remote attachment persistence
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# SQLITE Toggle (set to "true" for local tests without postgres)
USE_SQLITE=false

#LLM calls
GROQ_API_KEY="your-groq-api-key"
